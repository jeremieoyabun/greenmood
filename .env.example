# ============================================
# GREENMOOD V2 — Environment Variables
# ============================================

# --- AI ---
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Database ---
# Neon PostgreSQL connection string
# Get from https://console.neon.tech/ → Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/greenmood?sslmode=require

# --- Asset Storage ---
# Vercel Blob storage token for media uploads
# Get from https://vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxx

# --- App ---
# Public app URL (used for redirects, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Phase 2) ---
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_URL=http://localhost:3000

# --- Social APIs (Phase 3) ---
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_ACCESS_TOKEN=

# --- Intelligence (Phase 3) ---
# SERPER_API_KEY=            # Google Search API for intelligence agent
# NEWSAPI_KEY=               # News API for trend monitoring
